# LLM provider: ollama | anthropic | openai_compatible | gemini
# Groq goes through openai_compatible (verify model IDs at console.groq.com/docs/models)
LLM_PROVIDER=openai_compatible

ANTHROPIC_API_KEY=your-anthropic-key
GEMINI_API_KEY=your-gemini-key
OPENAI_COMPATIBLE_API_KEY=your-groq-or-other-key
OPENAI_COMPATIBLE_BASE_URL=https://api.groq.com/openai/v1
OPENAI_COMPATIBLE_MODEL=llama-3.3-70b-versatile
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Qdrant (local docker compose: no API key)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# API auth (fail-closed: requests are rejected if unset)
RAG_API_KEY=change-me

# Retrieval
RERANK_ENABLED=false
TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_FINAL=5

# Contract corpus TTL (startup sweep)
CONTRACT_TTL_HOURS=24
