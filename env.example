# LLM provider: ollama | anthropic | openai_compatible | gemini
# Groq goes through openai_compatible (verify model IDs at console.groq.com/docs/models)
LLM_PROVIDER=openai_compatible

ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-5
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash
OPENAI_COMPATIBLE_API_KEY=your-groq-or-other-key
OPENAI_COMPATIBLE_BASE_URL=https://api.groq.com/openai/v1
OPENAI_COMPATIBLE_MODEL=llama-3.3-70b-versatile
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Qdrant (local docker compose: no API key)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# Embedded-mode fallback (no docker): leave QDRANT_URL empty and set this to a
# local directory, e.g. data/qdrant_local. Single-process only.
QDRANT_PATH=

# API auth (fail-closed: requests are rejected if unset)
RAG_API_KEY=change-me

# CORS: comma-separated origins allowed cross-origin (empty = none allowed).
# Prod: set to the Vercel frontend's origin, e.g. https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=

# Per-IP rate limits (slowapi syntax). Prod: raise RATE_LIMIT_ASK once the
# Next.js BFF is the only caller (ARCHITECTURE §6), e.g. 60/minute.
RATE_LIMIT_ASK=10/minute
RATE_LIMIT_CONTRACTS=5/minute
RATE_LIMIT_ANALYZE=3/minute

# Global daily request budget across /ask + /analyze (public-demo backstop;
# in-memory counter, resets on date rollover or process restart). 0 = off.
DAILY_REQUEST_CAP=0

# Retrieval
RERANK_ENABLED=false
TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_FINAL=5
TOP_K_RERANK_CANDIDATES=50

# Contract corpus (upload hardening + retrieval + TTL startup sweep)
CONTRACT_TTL_HOURS=24
CONTRACT_MAX_MB=5
CONTRACT_MAX_PAGES=20
TOP_K_CONTRACT=3

# Contract analysis (/analyze): law articles retrieved per clause
TOP_K_ANALYZE=3
# Pause between clause LLM calls (seconds); raise to 3-5 if the LLM provider's
# per-minute token limit keeps returning 429 mid-report. 0 = off.
ANALYZE_CLAUSE_DELAY_SECONDS=0
